# ─── Backend URL ──────────────────────────────────────────────────────────────
# Locally (docker compose): http://localhost:5000
# Production (Render):      https://wishlist-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── App base URL (for og:image, invite links from server) ────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cloudinary (прямая загрузка фото с фронтенда) ────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=wishlist
