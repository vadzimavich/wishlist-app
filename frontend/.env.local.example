# ─── Backend URL ──────────────────────────────────────────────────────────────
# Locally (docker compose): http://localhost:5000
# Production (Render):      https://wishlist-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── App base URL (for og:image, invite links from server) ────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Яндекс Карты (для отображения места проведения) ────────────────────────────
# Получить ключ: https://developer.tech.yandex.ru/
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key
