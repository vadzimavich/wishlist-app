# ═══════════════════════════════════════════════════════════════════════════════
# WishList App — Переменные окружения
# ═══════════════════════════════════════════════════════════════════════════════
#
# 📌 Как использовать:
#   ────────────────────────────────────────────────────────────────────────────
#   🐳 Docker Compose (локально)  →  cp .env.example .env  →  docker compose up
#   🌐 Render (backend dashboard) →  ввести вручную в Dashboard Render-а
#   ▲ Vercel (frontend dashboard) →  ввести вручную в Dashboard Vercel-а
#   💻 .env.local (фронт локально) →  cp .env.example .env.local  (только frontend/)
#
# ═══════════════════════════════════════════════════════════════════════════════


# ─── 🐳 Docker Compose (локальная разработка) ──────────────────────────────────
# Эти переменные подхватываются docker-compose.yml из .env файла.
# Скопируй .env.example → .env, заполни своими значениями, запусти:
#   docker compose up -d

# JWT Secret Key — используется backend для подписи JWT-токенов.
# Минимум 32 символа. Сгенерировать:
#   openssl rand -base64 48
JWT_KEY=jW4vw03O7ZOVtiNIcIRm7MxSmC0/BqxZhHc5JeN/d0hYxoN5Zsbrm7/O4/344xEz


# ─── 🌐 Render (Backend — Dashboard) ───────────────────────────────────────────
# ⚠️  Все переменные ЗАКОММЕНТИРОВАНЫ — Render читает их напрямую из Dashboard,
#     а не из .env файла. Используй этот блок как чеклист при настройке.
#
# 📝 Как добавить в Render:
#   1. Открой Dashboard → Environment → Environment Variables
#   2. Добавь каждую переменную по отдельности (ключ = значение)
#   3. Нажми Save Changes → Deploy

# PostgreSQL строка подключения.
#   Локальный пример (Docker): Host=postgres;Database=wishlistdb;Username=postgres;Password=postgres;Ssl Mode=Disable
#   Render: берётся из Internal Database URL (вкладка Info твоей БД)
#   Supabase: Project Settings → Database → Connection string (URI)
# ConnectionStrings__DefaultConnection=Host=localhost;Database=wishlistdb;Username=postgres;Password=postgres;Ssl Mode=Disable

# JWT Secret Key — секретный ключ для подписи токенов.
#   Минимум 32 символа. Сгенерировать:
#     openssl rand -base64 48
#   Можно использовать то же значение, что и в JWT_KEY выше.
# Jwt__Key=your-secret-key-minimum-32-characters-long!!

# JWT Issuer — издатель токена. Должен совпадать с настройкой в JWT middleware.
#   Значение: wishlist-api
#   Изменять только если разворачиваешь несколько независимых API.
# Jwt__Issuer=wishlist-api

# JWT Audience — аудитория токена (клиент, которому разрешено использовать токен).
#   Значение: wishlist-client
# Jwt__Audience=wishlist-client

# CORS Allowed Origins — разрешённые источники для кросс-доменных запросов.
#   Через запятую (без пробелов). Для прода — только URL твоего фронтенда.
#   Пример: https://your-app.vercel.app,http://localhost:3000
# AllowedOrigins=https://your-app.vercel.app,http://localhost:3000

# Базовый URL приложения — используется в email-ссылках и редиректах.
#   Продакшен: https://your-app.vercel.app
#   Локально: http://localhost:3000
# App__BaseUrl=https://your-app.vercel.app


# ─── ▲ Vercel (Frontend — Dashboard) ────────────────────────────────────────────
# ⚠️  Все переменные ЗАКОММЕНТИРОВАНЫ — Vercel читает их напрямую из Dashboard
#     (Settings → Environment Variables), а не из .env файла.
#
# 📝 Как добавить в Vercel:
#   1. Открой Project Settings → Environment Variables
#   2. Добавь каждую переменную (ключ = значение)
#   3. Укажи scope: Production / Preview / Development
#   4. Redeploy при необходимости

# URL бэкенд API — все клиентские запросы идут сюда.
#   Продакшен: https://your-api.onrender.com
#   Локально: http://localhost:5000
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# API-ключ Яндекс.Карт — для отображения карты места проведения события.
#   Где взять: https://developer.tech.yandex.ru/ (кабинет разработчика)
#   Выбери "JavaScript API и HTTP Геокодер" → создай ключ
#   Бесплатный лимит: до 10000 запросов/сутки
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key


# ─── 💻 .env.local (локальный фронтенд, без Docker) ────────────────────────────
# Если запускаешь frontend отдельно (npm run dev), скопируй эту строку в
#   frontend/.env.local
# или
#   cp .env.example frontend/.env.local  (и раскомментируй строку ниже)

# NEXT_PUBLIC_API_URL=http://localhost:5000
